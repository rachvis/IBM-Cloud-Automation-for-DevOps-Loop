                                "diagram": {
                                    "caption": "IBM DevOps Loop on IKS — New Cluster flavor",
                                    "url": "https://raw.githubusercontent.com/YOUR_ORG/devops-loop-iks-da/main/reference-architecture/devops-loop-on-iks.svg",
                                    "metadata": []
                                },
                                "description": "This flavor provisions a new VPC, subnet, and IKS cluster, then installs Emissary-ingress as the API gateway and deploys IBM DevOps Loop via the OCI Helm chart from hclcr.io. Persistent storage is provided by IBM Cloud Block Storage (RWO) and File Storage (RWX). TLS is managed through IBM Secrets Manager. All eight SDLC capabilities — Plan, Code, Control, Build, Test, Release, Deploy, and Measure — are deployed in a dedicated Kubernetes namespace and can be individually toggled."
                            }
